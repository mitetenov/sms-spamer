# Telegram API credentials (required — obtain from https://my.telegram.org/apps)
TELEGRAM_API_ID=your_telegram_api_id
TELEGRAM_API_HASH=your_telegram_api_hash
# Telegram Bot Token (required — obtain from @BotFather)
BOT_TOKEN=
# Proxy (optional, for regions with restrictions)
PROXY_URL=
# HTTP request timeout in seconds
REQUEST_TIMEOUT=30
# Delay between requests to the same service (seconds)
SAME_SERVICE_DELAY=5
# Delay between different service requests (seconds)
BETWEEN_SERVICE_DELAY=2
